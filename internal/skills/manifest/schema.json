{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portico.dev/schema/skills/v1.json",
  "title": "Portico Skill Pack manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "version", "spec", "instructions", "binding"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*[a-z0-9]$",
      "description": "Lowercase id, dots permitted for namespace.name."
    },
    "title": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+([-+].+)?$",
      "description": "Semver — major.minor.patch[-prerelease][+build]."
    },
    "spec": { "type": "string", "const": "skills/v1" },
    "description": { "type": "string" },
    "instructions": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "^/" },
      "description": "Relative path to SKILL.md (no absolute paths)."
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "not": { "pattern": "^/" }
      }
    },
    "prompts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "not": { "pattern": "^/" }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "server_dependencies": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,31}$" }
        },
        "required_tools": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_-]+\\.[a-z0-9_.-]+$" }
        },
        "optional_tools": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_-]+\\.[a-z0-9_.-]+$" }
        },
        "policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requires_approval": {
              "type": "array",
              "items": { "type": "string", "pattern": "^[a-z0-9_-]+\\.[a-z0-9_.-]+$" }
            },
            "risk_classes": {
              "type": "object",
              "additionalProperties": {
                "type": "string",
                "enum": ["read", "write", "destructive", "external_side_effect", "sensitive_read"]
              }
            }
          }
        },
        "ui": {
          "type": "object",
          "additionalProperties": false,
          "required": ["resource_uri"],
          "properties": {
            "resource_uri": {
              "type": "string",
              "pattern": "^ui://"
            }
          }
        },
        "entitlements": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "plans": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
