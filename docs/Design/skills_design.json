      "desktop": {
        "minWidth": 1280,
        "idealWidth": 1440,
        "sidebarWidth": 208,
        "topbarHeight": 64,
        "inspectorWidth": 304,
        "contentGrid": "sidebar fixed, content fluid, inspector fixed"
      },
      "tablet": {
        "minWidth": 768,
        "sidebarWidth": 72,
        "inspectorMode": "drawer",
        "tableMode": "horizontal-scroll"
      },
      "mobile": {
        "maxWidth": 767,
        "sidebarMode": "bottom-nav-or-drawer",
        "inspectorMode": "full-screen-drawer",
        "tableMode": "skill-cards"
      }
    }
  },
  "page": {
    "id": "skills.index",
    "title": "Skills",
    "subtitle": "Attach workflow intelligence to MCP servers with reusable skill packs, prompts, resources, policies, and UI apps.",
    "primaryActions": [
      {
        "label": "Import Skill",
        "variant": "secondary",
        "icon": "Upload",
        "hasDropdown": true
      },
      {
        "label": "Validate Skills",
        "variant": "secondary",
        "icon": "BadgeCheck",
        "hasDropdown": false
      },
      {
        "label": "Create Skill",
        "variant": "primarySplit",
        "icon": "Plus",
        "hasDropdown": true
      }
    ],
    "layout": {
      "root": {
        "display": "grid",
        "gridTemplateColumns": "208px minmax(0, 1fr)",
        "minHeight": "100vh",
        "background": "color.background.canvas"
      },
      "appShell": {
        "display": "grid",
        "gridTemplateRows": "64px minmax(0, 1fr)",
        "minWidth": 0
      },
      "contentWithInspector": {
        "display": "grid",
        "gridTemplateColumns": "minmax(0, 1fr) 304px",
        "gap": 24,
        "padding": "28px 32px 32px 32px"
      }
    },
    "regions": {
      "sidebar": {
        "component": "SidebarNavigation",
        "activeItem": "Skills",
        "width": 208,
        "background": "color.background.sidebar",
        "borderRight": "1px solid rgba(255,255,255,0.08)",
        "padding": 16
      },
      "topbar": {
        "component": "Topbar",
        "height": 64,
        "background": "rgba(251, 250, 247, 0.82)",
        "backdropFilter": "blur(12px)",
        "borderBottom": "1px solid color.border.soft",
        "searchPlaceholder": "Search anything...",
        "shortcut": "⌘K"
      },
      "main": {
        "component": "SkillsCatalogWorkspace",
        "structure": [
          "pageHeader",
          "metricCards",
          "filterBar",
          "skillsTable",
          "pagination"
        ]
      },
      "inspector": {
        "component": "SkillInspector",
        "width": 304,
        "position": "sticky below topbar",
        "top": 88,
        "maxHeight": "calc(100vh - 112px)",
        "overflow": "auto"
      }
    },
    "components": {
      "PageHeader": {
        "layout": {
          "display": "flex",
          "justifyContent": "space-between",
          "alignItems": "flex-start",
          "gap": 24,
          "marginBottom": 24
        },
        "title": {
          "text": "Skills",
          "typography": "typography.usage.pageTitle"
        },
        "subtitle": {
          "text": "Attach workflow intelligence to MCP servers with reusable skill packs, prompts, resources, policies, and UI apps.",
          "typography": "typography.usage.pageSubtitle",
          "marginTop": 4
        }
      },
      "MetricCardRow": {
        "layout": {
          "display": "grid",
          "gridTemplateColumns": "repeat(5, minmax(0, 1fr))",
          "gap": 12,
          "marginBottom": 28
        },
        "card": {
          "height": 144,
          "padding": 18,
          "borderRadius": 12,
          "background": "color.background.surfaceRaised",
          "border": "1px solid color.border.soft",
          "shadow": "shadow.sm",
          "negativeSpace": {
            "topLabelToMetric": 10,
            "metricToHelper": 8,
            "helperToSparkline": 12,
            "iconToLabel": 10
          },
          "states": {
            "hover": {
              "border": "color.border.default",
              "shadow": "shadow.md"
            }
          }
        },
        "cards": [
          {
            "id": "skillsTotal",
            "label": "Skills",
            "metric": "48",
            "unit": "total",
            "helper": "36 enabled · 12 draft",
            "icon": "Blocks",
            "iconTone": "brand.primary",
            "sparklineTone": "dataViz.sparklineTeal"
          },
          {
            "id": "attachedServers",
            "label": "Attached Servers",
            "metric": "19",
            "unit": "servers",
            "helper": "Across 7 domains",
            "icon": "Network",
            "iconTone": "brand.primary",
            "sparklineTone": "dataViz.sparklineTeal"
          },
          {
            "id": "promptAssets",
            "label": "Prompt Assets",
            "metric": "124",
            "unit": "assets",
            "helper": "Prompts · guides · examples",
            "icon": "FileText",
            "iconTone": "text.secondary",
            "sparklineTone": "dataViz.sparklineTeal"
          },
          {
            "id": "uiApps",
            "label": "UI Apps",
            "metric": "18",
            "unit": "apps",
            "helper": "Embedded skill interfaces",
            "icon": "PanelTop",
            "iconTone": "text.secondary",
            "sparklineTone": "dataViz.sparklineTeal"
          },
          {
            "id": "approvalRules",
            "label": "Approval Rules",
            "metric": "9",
            "unit": "rules",
            "helper": "4 require review",
            "icon": "ShieldAlert",
            "iconTone": "status.review.base",
            "background": "color.status.review.subtle",
            "border": "color.status.review.border",
            "sparklineTone": "dataViz.sparklineWarm",
            "attention": "medium"
          }
        ]
      },
      "FilterBar": {
        "layout": {
          "display": "flex",
          "alignItems": "center",
          "gap": 8,
          "marginBottom": 14,
          "flexWrap": "nowrap"
        },
        "search": {
          "width": 224,
          "height": 34,
          "borderRadius": 9,
          "placeholder": "Search skills...",
          "background": "color.background.surfaceRaised",
          "border": "1px solid color.border.soft"
        },
        "chips": [
          "All",
          "Enabled",
          "Draft",
          "With UI",
          "Approval-gated"
        ],
        "dropdowns": [
          "Domain",
          "Server",
          "Plan",
          "Filters"
        ],
        "chip": {
          "height": 34,
          "paddingX": 12,
          "borderRadius": 9,
          "fontSize": 12,
          "fontWeight": 500,
          "states": {
            "default": {
              "background": "color.background.surfaceRaised",
              "border": "1px solid color.border.soft",
              "color": "color.text.secondary"
            },
            "hover": {
              "border": "color.border.default",
              "color": "color.text.primary"
            },
            "active": {
              "background": "color.brand.primarySubtle",
              "border": "1px solid color.brand.primary",
              "color": "color.brand.primaryInk"
            }
          }
        }
      },
      "SkillsTable": {
        "container": {
          "background": "color.background.surfaceRaised",
          "border": "1px solid color.border.soft",
          "borderRadius": 12,
          "overflow": "hidden",
          "shadow": "shadow.sm"
        },
        "columns": [
          {
            "id": "select",
            "label": "",
            "width": 42,
            "align": "center"
          },
          {
            "id": "skill",
            "label": "Skill",
            "width": 240,
            "align": "left"
          },
          {
            "id": "status",
            "label": "Status",
            "width": 88,
            "align": "left"
          },
          {
            "id": "domain",
            "label": "Domain",
            "width": 96,
            "align": "left"
          },
          {
            "id": "attachedServer",
            "label": "Attached Server",
            "width": 126,
            "align": "left"
          },
          {
            "id": "assets",
            "label": "Assets",
            "width": 132,
            "align": "left"
          },
          {
            "id": "policies",
            "label": "Policies",
            "width": 112,
            "align": "left"
          },
          {
            "id": "plan",
            "label": "Plan",
            "width": 92,
            "align": "left"
          },
          {
            "id": "version",
            "label": "Version",
            "width": 82,
            "align": "left"
          },
          {
            "id": "lastUpdated",
            "label": "Last updated",
            "width": 92,
            "align": "left"
          },
          {
            "id": "actions",
            "label": "Actions",
            "width": 52,
            "align": "right"
          }
        ],
        "header": {
          "height": 44,
          "background": "color.background.surfaceRaised",
          "borderBottom": "1px solid color.border.table",
          "typography": "typography.usage.tableHeader",
          "paddingX": 16
        },
        "row": {
          "height": 72,
          "paddingX": 16,
          "borderBottom": "1px solid color.border.table",
          "transition": "background-color 120ms, box-shadow 120ms, border-color 120ms",
          "states": {
            "default": {
              "background": "color.background.surfaceRaised"
            },
            "hover": {
              "background": "#FDFBF7"
            },
            "selected": {
              "background": "#F8FBFA",
              "boxShadow": "inset 0 0 0 1.5px #2D6F73",
              "borderColor": "#2D6F73"
            },
            "draft": {
              "background": "color.status.draft.subtle"
            },
            "review": {
              "background": "color.status.review.subtle"
            },
            "disabled": {
              "opacity": 0.58
            }
          },
          "negativeSpace": {
            "minHeight": "72px allows two-line skill identity, asset counts, and multiple badges without crowding.",
            "cellPadding": "16px horizontal and 14px vertical. Skills are catalog items and need more breathing room than raw logs.",
            "iconToTextGap": "12px between skill logo and text.",
            "badgeGap": "6px between adjacent badges.",
            "assetLineGap": "4px between prompt/resource/app asset lines.",
            "rightActionGutter": "Keep 12px right padding before the action menu."
          }
        },
        "skillIdentityCell": {
          "checkbox": {
            "size": 16,
            "borderRadius": 4,
            "checkedBackground": "color.brand.primary",
            "checkedColor": "#FFFFFF"
          },
