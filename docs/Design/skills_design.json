          },
          "humanName": {
            "typography": "typography.usage.skillName",
            "maxLines": 1
          }
        },
        "assetSummaryCell": {
          "typography": "typography.scale.caption",
          "color": "text.secondary",
          "format": "{prompts} prompts · {resources} resources · {apps} app",
          "lineBreakBehavior": "split into two lines when width is constrained"
        },
        "rows": [
          {
