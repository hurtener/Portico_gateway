          },
          {
            "id": "databricks.sql-analyst",
            "displayName": "SQL Analyst",
            "icon": "databricks",
            "status": "enabled",
            "domain": "data",
            "attachedServer": "databricks",
            "assets": {
              "prompts": 2,
              "resources": 4,
              "apps": 1
            },
            "policy": "approvalWrite",
            "plan": "enterprise",
            "version": "v1.2.0",
            "lastUpdated": "5h ago"
          },
          {
            "id": "linear.issue-triage",
            "displayName": "Issue Triage Assistant",
            "icon": "linear",
            "status": "draft",
            "domain": "devtools",
