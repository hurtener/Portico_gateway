{
  "$schema": "https://portico.dev/schemas/ui-spec.v0.json",
  "specName": "Portico Skills Page UI Spec",
  "version": "0.1.0",
  "status": "draft",
  "surface": "Portico Gateway Console",
  "pageId": "skills.index",
  "description": "Detailed UI specification for the Portico Skills page: visual tokens, card structure, typography, color usage, spacing, negative space, interactions, component states, and responsive behavior.",
  "designIntent": {
    "pagePurpose": "Let operators and agent builders discover, inspect, attach, govern, test, and manage reusable skill packs connected to MCP servers.",
    "mood": [
      "calm",
      "architectural",
      "agent-builder friendly",
      "operational",
      "curated",
      "trustworthy",
      "technical but approachable"
    ],
    "principles": [
      "Make skill packs feel like curated workflow modules, not raw prompt files.",
      "Show the relationship between skills, MCP servers, tools, prompts, resources, policies, and UI apps at a glance.",
      "Keep operational density balanced with enough negative space to make catalog browsing feel calm.",
      "Use the same architectural console language as the Servers page for continuity.",
      "Use policy and approval states clearly; skills often wrap high-impact tool behavior.",
      "Reveal implementation detail progressively through the right inspector and detail pages."
    ],
    "visualMetaphor": "A curated library of workflow intelligence attached to governed gateways and servers. Skills are reusable packages that turn raw MCP capabilities into reliable agent behavior."
  },
