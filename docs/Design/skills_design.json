    "avoid": [
      "making skills look like plain prompt snippets",
      "showing too much manifest YAML in the index table",
      "using aggressive colors for every domain badge",
      "overcrowding the inspector with full instructions",
      "hiding policy information behind a details page only",
      "status indicated only by color"
