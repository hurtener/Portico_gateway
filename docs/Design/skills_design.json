    "spacing": {
      "baseUnit": 4,
      "scale": {
        "0": 0,
        "1": 4,
        "2": 8,
        "3": 12,
        "4": 16,
        "5": 20,
        "6": 24,
        "8": 32,
        "10": 40,
        "12": 48,
        "16": 64,
        "20": 80,
        "24": 96
      },
      "semantic": {
        "pagePaddingX": 32,
        "pagePaddingY": 28,
        "sectionGap": 28,
        "cardPadding": 20,
        "cardPaddingCompact": 16,
        "tableCellPaddingX": 16,
        "tableCellPaddingY": 14,
        "controlGap": 8,
        "filterGap": 8,
        "sidebarPadding": 16,
        "inspectorPadding": 20,
        "inspectorSectionGap": 14
      },
      "negativeSpace": {
        "pageOuterMargin": "Use 32px horizontal and 28px vertical content padding on desktop. The Skills page is a catalog and should feel more browseable than a pure operations page.",
        "headerToMetrics": "Use 24px between page subtitle and metric cards. Skills are conceptual assets, so give the header enough breathing room before numbers appear.",
        "metricsToFilterBar": "Use 28px. This separates global catalog state from browsing/filtering actions.",
        "filterBarToTable": "Use 14px. Filters directly control the table and should remain visually connected.",
        "tableRowBreathing": "Rows should be 72px minimum height because each skill row includes an icon, skill ID, human-readable title, status, domain, attached server, asset counts, policy, plan, version, and action menu.",
        "skillIdentityBreathing": "Use 12px between skill icon and text. Skill IDs should not collide visually with human-readable names.",
        "inspectorBreathing": "Inspector sections should use 14px gaps and 16px card padding. The inspector is a summary, not a configuration form.",
        "assetGrouping": "Prompt/resource/app asset counts should appear in a compact two-line grouping with at least 4px between asset rows to preserve legibility.",
        "whiteSpaceRatio": "Target 30% to 38% negative space in the main content area. The Skills page should feel like a curated catalog, less dense than logs or raw tool tables.",
        "rightGutter": "Preserve a 24px gutter between the table and inspector. Skills include descriptive text, so the inspector needs separation to avoid visual noise."
      }
    },
    "radius": {
      "xs": 6,
      "sm": 8,
      "md": 12,
      "lg": 16,
      "xl": 20,
      "pill": 999
    },
    "shadow": {
      "none": "none",
      "sm": "0 1px 2px rgba(16, 24, 40, 0.04)",
      "md": "0 4px 12px rgba(16, 24, 40, 0.06)",
      "lg": "0 12px 32px rgba(16, 24, 40, 0.08)",
      "focusRing": "0 0 0 3px rgba(45, 111, 115, 0.18)"
    },
    "motion": {
      "duration": {
        "instant": "80ms",
        "fast": "120ms",
        "normal": "180ms",
        "slow": "240ms"
      },
      "easing": {
        "standard": "cubic-bezier(0.2, 0.0, 0.0, 1.0)",
        "out": "cubic-bezier(0.16, 1, 0.3, 1)",
        "in": "cubic-bezier(0.32, 0, 0.67, 0)"
      }
    },
