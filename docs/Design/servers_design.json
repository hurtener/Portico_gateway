          "fontSize": 14,
          "lineHeight": 22,
          "fontWeight": 400
        },
        "bodySm": {
          "fontSize": 13,
          "lineHeight": 20,
          "fontWeight": 400
        },
        "caption": {
          "fontSize": 12,
          "lineHeight": 18,
          "fontWeight": 400
        },
        "label": {
          "fontSize": 12,
          "lineHeight": 16,
          "fontWeight": 600,
          "letterSpacing": "0.01em"
        },
        "metric": {
          "fontSize": 28,
          "lineHeight": 34,
          "fontWeight": 600,
          "letterSpacing": "-0.03em"
        },
        "monoSm": {
          "fontSize": 12,
          "lineHeight": 18,
          "fontWeight": 500,
          "fontFamily": "mono"
        },
        "monoXs": {
          "fontSize": 11,
          "lineHeight": 16,
          "fontWeight": 500,
          "fontFamily": "mono"
        }
      },
      "usage": {
        "pageTitle": {
          "family": "display",
          "token": "h1",
          "color": "text.primary"
        },
        "pageSubtitle": {
          "family": "ui",
          "token": "body",
          "color": "text.secondary"
        },
        "sidebarBrand": {
          "family": "display",
          "fontSize": 22,
          "lineHeight": 28,
          "fontWeight": 600,
          "letterSpacing": "0.16em",
          "textTransform": "uppercase",
          "color": "text.inverse"
        },
        "cardLabel": {
          "family": "ui",
          "token": "label",
          "color": "text.secondary"
        },
        "tableHeader": {
          "family": "ui",
          "fontSize": 12,
          "lineHeight": 16,
          "fontWeight": 500,
          "color": "text.tertiary"
        },
        "tablePrimary": {
          "family": "ui",
          "token": "bodySm",
          "fontWeight": 600,
          "color": "text.primary"
        },
        "tableSecondary": {
          "family": "ui",
          "token": "caption",
          "color": "text.secondary"
        }
      }
    },
    "spacing": {
      "baseUnit": 4,
      "scale": {
        "0": 0,
        "1": 4,
        "2": 8,
        "3": 12,
        "4": 16,
        "5": 20,
        "6": 24,
        "8": 32,
        "10": 40,
        "12": 48,
        "16": 64,
        "20": 80,
        "24": 96
      },
      "semantic": {
        "pagePaddingX": 32,
        "pagePaddingY": 28,
        "sectionGap": 28,
        "cardPadding": 20,
        "cardPaddingCompact": 16,
        "tableCellPaddingX": 16,
        "tableCellPaddingY": 14,
        "controlGap": 8,
        "filterGap": 8,
        "sidebarPadding": 16,
        "sidebarItemGap": 6,
        "inspectorPadding": 20,
        "inspectorSectionGap": 16
      },
      "negativeSpace": {
        "pageOuterMargin": "The main content should breathe around the top, left, and right edges. Use 32px horizontal padding and 28px top padding on desktop. Avoid pushing content flush against the topbar or inspector.",
        "betweenHeaderAndMetrics": "Use 24px between the page heading block and the metric cards. This creates a calm pause before operational data begins.",
        "betweenMetricsAndFilters": "Use 28px between the metric row and the filter/search row. This separates high-level status from table operations.",
        "betweenFiltersAndTable": "Use 14px between filters and the table. The relationship should feel direct, but not cramped.",
        "tableRowBreathing": "Rows should be 64px minimum height. Server rows include primary and secondary text, badges, and action menu; allow enough vertical room to avoid enterprise-console density.",
        "inspectorBreathing": "Inspector sections use 16px vertical gap and 20px padding. Each section should look like a calm stack of small facts, not a compressed form.",
        "sidebarBreathing": "Sidebar groups should have 24px vertical separation. Items use 40px height with 8px internal gap to keep navigation clear in a dark surface.",
        "whiteSpaceRatio": "Target roughly 28% to 36% negative space in the main content area on a 1440px desktop viewport. Dense pages may fall to 24%, but should never look like a spreadsheet-first admin console.",
        "emptyRightGutters": "Preserve a 24px gutter between the main table and right inspector. This visual break prevents the inspector from feeling glued to the operational table.",
        "cardInteriorWhitespace": "Metric cards should not be packed. Leave 12px between label and metric, 12px between metric and helper text, and at least 10px above miniature sparklines."
      }
    },
    "radius": {
      "xs": 6,
      "sm": 8,
      "md": 12,
      "lg": 16,
      "xl": 20,
      "pill": 999
    },
    "shadow": {
      "none": "none",
      "sm": "0 1px 2px rgba(16, 24, 40, 0.04)",
      "md": "0 4px 12px rgba(16, 24, 40, 0.06)",
      "lg": "0 12px 32px rgba(16, 24, 40, 0.08)",
      "sidebarInset": "inset -1px 0 0 rgba(255,255,255,0.08)",
      "focusRing": "0 0 0 3px rgba(45, 111, 115, 0.18)"
    },
    "border": {
      "width": {
        "hairline": 1,
        "focus": 2
      },
      "style": "solid"
    },
    "motion": {
      "duration": {
        "instant": "80ms",
        "fast": "120ms",
        "normal": "180ms",
        "slow": "240ms"
      },
      "easing": {
        "standard": "cubic-bezier(0.2, 0.0, 0.0, 1.0)",
        "out": "cubic-bezier(0.16, 1, 0.3, 1)",
        "in": "cubic-bezier(0.32, 0, 0.67, 0)"
      },
      "rules": [
        "Use subtle transitions only: opacity, border color, background color, transform up to 1px, and panel slide.",
        "Avoid bouncy animation in the console; this is an operational system.",
        "Use skeleton shimmer only in low-opacity neutral tones."
      ]
    },
    "layout": {
      "desktop": {
        "minWidth": 1280,
        "idealWidth": 1440,
        "sidebarWidth": 208,
        "topbarHeight": 64,
        "inspectorWidth": 304,
        "mainMaxWidth": "none",
        "contentGrid": "sidebar fixed, content fluid, inspector fixed"
      },
      "tablet": {
        "minWidth": 768,
        "sidebarWidth": 72,
        "inspectorMode": "drawer",
        "tableMode": "horizontal-scroll"
      },
      "mobile": {
        "maxWidth": 767,
        "sidebarMode": "bottom-nav-or-drawer",
        "inspectorMode": "full-screen-drawer",
        "tableMode": "server-cards"
      }
    }
  },
  "page": {
    "id": "servers.index",
    "title": "MCP Servers",
    "subtitle": "Manage registered MCP servers, runtime modes, health, exposed capabilities, and policies.",
    "layout": {
      "root": {
        "display": "grid",
        "gridTemplateColumns": "208px minmax(0, 1fr)",
        "minHeight": "100vh",
        "background": "color.background.canvas"
      },
      "appShell": {
        "display": "grid",
        "gridTemplateRows": "64px minmax(0, 1fr)",
        "minWidth": 0
      },
      "contentWithInspector": {
        "display": "grid",
        "gridTemplateColumns": "minmax(0, 1fr) 304px",
        "gap": 24,
        "padding": "28px 32px 32px 32px"
      }
    },
    "regions": {
      "sidebar": {
        "component": "SidebarNavigation",
        "width": 208,
        "background": "color.background.sidebar",
        "borderRight": "1px solid rgba(255,255,255,0.08)",
        "padding": 16,
        "structure": [
          "brandLockup",
          "primaryNavigation",
          "gatewayGroup",
          "systemGroup",
          "statusCard"
        ],
        "negativeSpace": {
          "brandToOverviewGap": 28,
          "groupGap": 24,
          "statusCardBottomInset": 16
        }
      },
      "topbar": {
        "component": "Topbar",
        "height": 64,
        "background": "rgba(251, 250, 247, 0.82)",
        "backdropFilter": "blur(12px)",
        "borderBottom": "1px solid color.border.soft",
        "contentAlignment": "search centered, utilities right",
        "paddingX": 32
      },
      "main": {
        "component": "ServerRegistryWorkspace",
        "structure": [
          "pageHeader",
          "metricCards",
          "filterBar",
          "serverTable",
          "pagination"
        ]
      },
      "inspector": {
        "component": "ServerInspector",
        "width": 304,
        "position": "sticky below topbar",
        "top": 88,
        "maxHeight": "calc(100vh - 112px)",
        "overflow": "auto"
      }
    },
    "components": {
      "SidebarNavigation": {
        "brandLockup": {
          "height": 48,
          "display": "flex",
          "alignItems": "center",
          "gap": 12,
          "logo": {
            "size": 34,
            "color": "rgba(243,245,246,0.78)",
            "style": "line-art portico arch"
          },
          "wordmark": {
            "text": "PORTICO",
            "typography": "typography.usage.sidebarBrand"
          }
        },
        "navItem": {
          "height": 40,
          "padding": "0 12px",
          "borderRadius": 10,
          "gap": 10,
          "iconSize": 17,
          "typography": {
            "fontSize": 13,
            "lineHeight": 20,
            "fontWeight": 500
          },
          "states": {
            "default": {
              "background": "transparent",
              "text": "rgba(243,245,246,0.76)",
              "icon": "rgba(243,245,246,0.70)"
            },
            "hover": {
              "background": "rgba(255,255,255,0.06)",
              "text": "#FFFFFF",
              "icon": "#FFFFFF"
            },
            "active": {
              "background": "linear-gradient(90deg, rgba(45,111,115,0.95), rgba(36,93,97,0.72))",
              "text": "#FFFFFF",
              "icon": "#FFFFFF",
              "shadow": "inset 0 0 0 1px rgba(255,255,255,0.08)"
            },
            "focus": {
              "outline": "none",
              "boxShadow": "0 0 0 3px rgba(216,234,232,0.20)"
            }
          }
        },
        "groupLabel": {
          "fontSize": 11,
          "lineHeight": 14,
          "fontWeight": 600,
          "letterSpacing": "0.06em",
          "textTransform": "uppercase",
          "color": "rgba(243,245,246,0.52)",
          "marginBottom": 8
        },
        "statusCard": {
          "position": "near bottom",
          "padding": 16,
          "borderRadius": 12,
          "background": "rgba(255,255,255,0.055)",
          "border": "1px solid rgba(255,255,255,0.10)",
          "title": "Portico Gateway",
          "version": "v0.3.0",
          "status": "All systems operational",
          "statusColor": "#76D39A"
        }
      },
      "Topbar": {
        "search": {
          "width": 320,
          "height": 36,
          "borderRadius": 10,
          "background": "color.background.surfaceRaised",
          "border": "1px solid color.border.soft",
          "placeholder": "Search anything...",
          "shortcut": "⌘K",
          "states": {
            "default": {
              "border": "color.border.soft"
            },
            "hover": {
              "border": "color.border.default"
            },
            "focus": {
              "border": "color.border.focus",
              "boxShadow": "shadow.focusRing"
            }
          }
        },
        "utilityIconButton": {
          "size": 36,
          "borderRadius": 10,
          "background": "transparent",
          "iconColor": "color.icon.default",
          "states": {
            "hover": {
              "background": "color.background.surfaceSubtle",
              "iconColor": "color.text.primary"
            },
            "active": {
              "background": "color.brand.primarySubtle",
              "iconColor": "color.brand.primary"
            }
          }
        },
        "userMenu": {
          "avatarSize": 36,
          "avatarBackground": "#343A40",
          "avatarText": "#FFFFFF",
          "nameTypography": "typography.scale.bodySm",
          "orgTypography": "typography.scale.caption"
        }
      },
      "PageHeader": {
        "layout": {
          "display": "flex",
          "justifyContent": "space-between",
          "alignItems": "flex-start",
          "gap": 24,
          "marginBottom": 24
        },
        "title": {
          "text": "MCP Servers",
          "typography": "typography.usage.pageTitle"
        },
        "subtitle": {
          "text": "Manage registered MCP servers, runtime modes, health, exposed capabilities, and policies.",
          "typography": "typography.usage.pageSubtitle",
          "marginTop": 4
        },
        "actions": [
          {
            "label": "Import Config",
            "variant": "secondary",
            "icon": null,
            "hasDropdown": true
          },
          {
            "label": "Refresh Catalog",
            "variant": "secondary",
            "icon": "RefreshCw",
            "hasDropdown": true
          },
          {
            "label": "Add Server",
            "variant": "primarySplit",
            "icon": "Plus",
            "hasDropdown": true
          }
        ]
      },
      "Button": {
        "sizes": {
          "sm": {
            "height": 32,
            "paddingX": 12,
            "fontSize": 12
          },
          "md": {
            "height": 40,
            "paddingX": 16,
            "fontSize": 13
          },
          "lg": {
            "height": 48,
            "paddingX": 20,
            "fontSize": 14
          }
        },
        "base": {
          "borderRadius": 10,
          "fontWeight": 600,
          "transition": "background-color 120ms, border-color 120ms, transform 120ms, box-shadow 120ms"
        },
        "variants": {
          "primary": {
            "background": "linear-gradient(180deg, #2D6F73 0%, #245D61 100%)",
            "border": "1px solid #1D4D50",
            "color": "#FFFFFF",
            "shadow": "0 1px 2px rgba(16,24,40,0.08)",
            "hover": {
              "background": "#245D61"
            },
            "active": {
              "background": "#1D4D50",
              "transform": "translateY(1px)"
            }
          },
          "secondary": {
            "background": "color.background.surfaceRaised",
            "border": "1px solid color.border.default",
            "color": "color.text.primary",
            "hover": {
              "background": "color.background.surfaceSubtle",
              "border": "color.border.strong"
            }
          },
          "ghost": {
            "background": "transparent",
            "border": "1px solid transparent",
            "color": "color.text.secondary",
            "hover": {
              "background": "color.background.surfaceSubtle",
              "color": "color.text.primary"
            }
          },
          "destructiveOutline": {
            "background": "transparent",
            "border": "1px solid color.status.danger.base",
            "color": "color.status.danger.base",
            "hover": {
              "background": "color.status.danger.subtle"
            }
          }
        }
      },
      "MetricCardRow": {
        "layout": {
          "display": "grid",
          "gridTemplateColumns": "repeat(5, minmax(0, 1fr))",
          "gap": 12,
          "marginBottom": 28
        },
        "card": {
          "height": 144,
          "padding": 18,
          "borderRadius": 12,
          "background": "color.background.surfaceRaised",
          "border": "1px solid color.border.soft",
          "shadow": "shadow.sm",
          "states": {
            "hover": {
              "border": "color.border.default",
              "shadow": "shadow.md"
            }
          },
          "negativeSpace": {
            "topLabelToMetric": 10,
            "metricToHelper": 8,
            "helperToSparkline": 12,
            "iconToLabel": 10
          }
        },
        "cards": [
          {
            "id": "servers",
            "label": "Servers",
            "metric": "12",
            "unit": "total",
            "helper": "11 online · 1 offline",
            "icon": "Server",
            "iconTone": "brand.primary",
            "sparklineTone": "dataViz.sparklineTeal"
          },
          {
            "id": "runtimeProcesses",
            "label": "Runtime Processes",
            "metric": "34",
            "unit": "active",
            "helper": "8 idle · 2 restarting",
            "icon": "Workflow",
            "iconTone": "brand.primary",
            "sparklineTone": "dataViz.sparklineTeal"
          },
          {
            "id": "capabilities",
            "label": "Capabilities",
            "metric": "184",
            "unit": "tools",
            "helper": "39 resources · 22 prompts",
            "icon": "Box",
            "iconTone": "text.secondary",
            "sparklineTone": "dataViz.sparklineWarm"
          },
          {
            "id": "policies",
            "label": "Policies",
            "metric": "27",
            "unit": "enforced",
            "helper": "3 approval-gated",
            "icon": "Shield",
            "iconTone": "text.secondary",
            "sparklineTone": "dataViz.sparklineWarm"
          },
          {
            "id": "catalogDrift",
            "label": "Catalog Drift",
            "metric": "2",
            "unit": "changed",
            "helper": "Review required",
            "icon": "ShieldAlert",
            "iconTone": "status.warning.base",
            "background": "color.status.warning.subtle",
            "border": "color.status.warning.border",
            "sparklineTone": "dataViz.sparklineWarm",
            "attention": "medium"
          }
        ]
      },
      "FilterBar": {
        "layout": {
          "display": "flex",
          "alignItems": "center",
          "gap": 8,
          "marginBottom": 14,
          "flexWrap": "nowrap"
        },
        "search": {
          "width": 176,
          "height": 34,
          "borderRadius": 9,
          "placeholder": "Search servers...",
          "background": "color.background.surfaceRaised",
          "border": "1px solid color.border.soft"
        },
        "chips": [
          "All",
          "Online",
          "Offline",
          "Needs review",
          "Has skills",
          "Auth error"
        ],
        "dropdowns": [
          "Transport",
          "Runtime",
          "Scope",
          "Filters"
        ],
        "chip": {
          "height": 34,
          "paddingX": 12,
          "borderRadius": 9,
          "fontSize": 12,
          "fontWeight": 500,
          "states": {
            "default": {
              "background": "color.background.surfaceRaised",
              "border": "1px solid color.border.soft",
              "color": "color.text.secondary"
            },
            "hover": {
              "border": "color.border.default",
              "color": "color.text.primary"
            },
