          "letterSpacing": "-0.025em"
        },
        "h2": {
          "fontSize": 24,
          "lineHeight": 32,
          "fontWeight": 600,
          "letterSpacing": "-0.02em"
        },
        "h3": {
          "fontSize": 18,
          "lineHeight": 26,
          "fontWeight": 600,
          "letterSpacing": "-0.01em"
        },
        "title": {
          "fontSize": 16,
          "lineHeight": 24,
          "fontWeight": 600
        },
