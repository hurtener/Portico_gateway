{
  "$schema": "https://portico.dev/schemas/ui-spec.v0.json",
  "specName": "Portico Servers Page UI Spec",
  "version": "0.1.0",
  "status": "draft",
  "surface": "Portico Gateway Console",
  "pageId": "servers.index",
  "description": "Detailed UI specification for the Portico MCP Servers page: visual tokens, card structure, typography, colors, spacing, negative space, interactions, and component states.",
  "designIntent": {
    "mood": [
      "calm",
      "architectural",
      "trustworthy",
      "operational",
      "premium infrastructure",
      "technical but humane"
    ],
    "principles": [
      "Use restrained contrast and typography to create hierarchy instead of excessive decoration.",
      "Favor structured surfaces over floating cards everywhere.",
      "Make health, risk, policy, runtime, and credential state instantly legible.",
      "Use negative space deliberately so the dense operational content still feels calm.",
      "Keep the page useful at a glance, then reveal detail progressively through inspector panels and drawers.",
      "Avoid neon, cyberpunk, generic cloud-console blue, or overly playful SaaS styling."
    ],
    "visualMetaphor": "A controlled architectural threshold: many external MCP servers pass through one governed, observable gateway."
  },
  "tokens": {
